# ── Vertex AI (primary — Track 3 requirement) ────────────────────────────────
# ADK + sanbi_core route all Gemini calls through Vertex AI when this is TRUE.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Local dev auth (pick ONE):
#   1. gcloud auth application-default login          ← easiest
#   2. GOOGLE_APPLICATION_CREDENTIALS=/path/key.json  ← service account
# GOOGLE_APPLICATION_CREDENTIALS=

# ── OpenAI (second audit engine) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Models ───────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
GEMINI_GRADING_MODEL=gemini-2.5-flash
ADK_AGENT_MODEL=gemini-2.5-flash

# ── Optional: local fallback without a GCP project (dev only) ────────────────
# If GOOGLE_GENAI_USE_VERTEXAI is not TRUE, sanbi_core falls back to an
# API-key Gemini client. The hackathon deployment uses Vertex.
# GEMINI_API_KEY=
